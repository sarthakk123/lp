#!/usr/bin/env python3
"""Graph Coloring - CSP with step-by-step terminal output"""

class GraphColoring:
    def __init__(self, vertices, edges, colors):
        self.v = list(vertices)
        self.adj = {x: set() for x in vertices}
        for u, w in edges:
            self.adj[u].add(w); self.adj[w].add(u)
        self.c = colors
        self.color = {x: -1 for x in vertices}
        self.steps = 0

    def is_safe(self, v, col):
        return all(self.color[nb] != col for nb in self.adj[v])

    def solve(self, idx=0):
        if idx == len(self.v):
            return True
        for col in range(self.c):
            self.steps += 1
            if self.is_safe(self.v[idx], col):
                self.color[self.v[idx]] = col
                print(f"  Step {self.steps}: V{self.v[idx]} -> C{col} [ACCEPTED]")
                if self.solve(idx + 1):
                    return True
                self.color[self.v[idx]] = -1
            else:
                print(f"  Step {self.steps}: V{self.v[idx]} -> C{col} [REJECTED]")
        return False

    def print_result(self):
        print(f"\n{'='*40}")
        print(f"Solution found! (Steps: {self.steps})")
        print("\n  Coloring:")
        for v in self.v:
            print(f"    Vertex {v}: Color {self.color[v]}")

def main():
    n = int(input("Vertices: "))
    e = int(input("Edges: "))
    vertices = set(range(1, n+1))
    edges = []
    print("Edges (u v):")
    for _ in range(e):
        u, w = map(int, input().split())
        edges.append((u, w)); vertices.add(u); vertices.add(w)
    c = int(input("Colors: "))

    solver = GraphColoring(vertices, edges, c)
    print("\nSolving...\n")
    if solver.solve():
        solver.print_result()
    else:
        print(f"No solution with {c} colors")

if __name__ == "__main__":
    main()