from collections import defaultdict, deque

def bfs(adj, visited, start):
    queue = deque([(start, 0)])
    visited.add(start)
    order = []
    levels = {}
    while queue:
        node, level = queue.popleft()
        order.append(node)
        levels[node] = level
        for neighbor in sorted(adj[node]):
            if neighbor not in visited:
                visited.add(neighbor)
                queue.append((neighbor, level + 1))
    return order, levels

def main():
    n = int(input("Enter number of nodes: "))
    e = int(input("Enter number of edges: "))
    adj = defaultdict(list)
    print("Enter edges (u v):")
    for _ in range(e):
        u, v = map(int, input().split())
        adj[u].append(v)
        adj[v].append(u)

    start = int(input("Enter start node: "))
    visited = set()

    print(f"\nBFS from {start}:")
    order, levels = bfs(adj, visited, start)
    print(" -> ".join(map(str, order)))
    print(f"Total visited: {len(order)}")

    for level in range(max(levels.values()) + 1):
        nodes = [n for n, l in levels.items() if l == level]
        print(f"  Level {level}: {sorted(nodes)}")
    print(f"Total levels: {max(levels.values()) + 1 if levels else 0}")

if __name__ == "__main__":
    main()
