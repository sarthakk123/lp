def choice():

    products = []
    total = 0

    while True:

        print("\nEnter product name (pizza / mango juice / apple juice)")
        print("Type 'done' to finish order")

        a = input().lower()

        if a == "done":
            break

        elif a == "pizza":

            products.append(("Pizza", 200))
            total += 200

        elif a == "mango juice":

            products.append(("Mango Juice", 70))
            total += 70

        elif a == "apple juice":

            products.append(("Apple Juice", 80))
            total += 80

        else:
            print("Invalid item, try again!")

    if len(products) == 0:

        print("No product selected. Thank you!")
        return

    print("\nYou selected:")

    for item in products:
        print(item[0], ":", item[1])

    print("Total Price:", total)

    order(total, products)


