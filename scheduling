#!/usr/bin/env python3
"""
Job Sequencing with Deadlines - Greedy Algorithm
"""
def job_sequencing(jobs):
    jobs = sorted(jobs, key=lambda x: x[1], reverse=True)
    max_deadline = max(j[2] for j in jobs)
    slot = [None] * max_deadline
    scheduled, profit = [], 0

    for job_id, p, d in jobs:
        for s in range(min(d, max_deadline) - 1, -1, -1):
            if slot[s] is None:
                slot[s] = job_id
                scheduled.append((job_id, p, d, s+1))
                profit += p
                break

    return scheduled, profit, slot, max_deadline

def main():
    n = int(input("Enter number of jobs: "))
    jobs = []
    print("Enter jobs (id profit deadline):")
    for _ in range(n):
        job_id, profit, deadline = input().split()
        jobs.append((job_id, int(profit), int(deadline)))

    scheduled, profit, slot, max_d = job_sequencing(jobs)

    print(f"\nScheduled jobs: {scheduled}")
    print(f"Total profit: {profit}")

    print("\nGantt Chart:")
    print("+" + "+".join(["-" * 8] * max_d) + "+")
    row = "|"
    for s in slot:
        row += f"  {s or 'idle':^5}  |"
    print(row)
    print("+" + "+".join(["-" * 8] * max_d) + "+")

if __name__ == "__main__":
    main()